{
  "name": "web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "typecheck": "pnpm check",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:codegen": "playwright codegen",
    "test:record": "playwright codegen http://localhost:5173 --output tests/recorded.spec.ts",
    "test:record:user1": "playwright codegen http://localhost:5173 --output tests/_temp-user1.spec.ts",
    "test:record:user2": "playwright codegen http://localhost:5173 --output tests/_temp-user2.spec.ts",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@iconify/svelte": "5.2.1",
    "@playwright/test": "1.57.0",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.50.0",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.1.18",
    "@tanstack/svelte-query": "6.0.17",
    "@tanstack/svelte-query-devtools": "6.0.3",
    "@trpc/client": "11.8.1",
    "@trpc/server": "11.8.1",
    "@zenstackhq/orm": "3.2.1",
    "@zenstackhq/tanstack-query": "3.2.1",
    "buffer": "6.0.3",
    "daisyui": "5.5.14",
    "nanoid": "5.1.6",
    "prettier": "3.8.0",
    "prettier-plugin-svelte": "3.4.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "server": "link:../server",
    "superjson": "2.2.6",
    "svelecte": "5.3.0",
    "svelte": "5.47.1",
    "svelte-check": "4.3.5",
    "svelte-french-toast": "1.2.0",
    "tailwindcss": "4.1.18",
    "typescript": "6.0.0-dev.20251210",
    "vite": "7.3.1",
    "vite-plugin-node-polyfills": "0.25.0",
    "zenstack-trpc": "0.1.20",
    "zod": "4.3.5"
  }
}
